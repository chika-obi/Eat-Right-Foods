rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSystemAdmin() {
      return isSignedIn() && 
             ((request.auth.token.get('email', '').lower() == 'kpanukuchikaobi@gmail.com'.lower()) || 
              (request.auth.token.get('email', '').lower() == 'admin@eatright.com'.lower()));
    }

    function isAdmin() {
      return isSignedIn() && (
        isSystemAdmin() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', 'member') == 'admin')
      );
    }

    function isStatusUpdateOnly(data, existingData) {
      return data.diff(existingData).affectedKeys().hasOnly(['status']);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidProfile(data) {
      return (data.displayName is string && data.displayName.size() <= 100) &&
             (data.email is string && data.email.size() <= 100) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('role' in data) || (data.role is string)) &&
             (!('emailVerified' in data) || (data.emailVerified is bool)) &&
             (!('addresses' in data) || (data.addresses is list)) &&
             (!('paymentMethods' in data) || (data.paymentMethods is list));
    }

    function isValidProfileUpdate(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('role' in data) || (data.role is string)) &&
             (!('emailVerified' in data) || (data.emailVerified is bool)) &&
             (!('addresses' in data) || (data.addresses is list)) &&
             (!('paymentMethods' in data) || (data.paymentMethods is list));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'date', 'items', 'total', 'status']) &&
             data.id is string &&
             data.date is string &&
             data.items is list &&
             data.total is number &&
             data.status in ['pending', 'preparing', 'dispatched', 'delivered', 'cancelled'];
    }

    function isValidProduct(data) {
      return (data.name is string && data.name.size() <= 100) &&
             (data.price is number && data.price >= 0) &&
             (data.category is string) &&
             (data.image is string) &&
             (!('calories' in data) || data.calories is number) &&
             (!('protein' in data) || data.protein is number) &&
             (!('carbs' in data) || data.carbs is number) &&
             (!('fiber' in data) || data.fiber is number) &&
             (!('isAvailable' in data) || data.isAvailable is bool) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('reviews' in data) || (data.reviews is list)) &&
             (!('id' in data) || data.id is string);
    }

    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isSystemAdmin();
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Match profiles
    match /profiles/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if (isOwner(userId) && isValidProfileUpdate(incoming()) && !incoming().diff(existing()).affectedKeys().hasAny(['role'])) || 
                       (isAdmin() && isValidProfileUpdate(incoming()));

      match /orders/{orderId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidOrder(incoming());
        allow update: if isAdmin() || 
                         (isOwner(userId) && incoming().status == 'cancelled' && existing().status == 'pending');
        allow delete: if isAdmin();
      }
    }

    // Collection group for global order access
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
  }
}
